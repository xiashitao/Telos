# Telos 生产 .env.local 示例 —— 复制到 <REPO>/.env.local 并填值

# ── AI（缺失时 AI 功能返回 503，其余功能不受影响）──
ANTHROPIC_API_KEY=
# AI_MODEL=claude-sonnet-5

# ── 统一登录网关（双模式：开启不会上锁，只是接入登录能力）──
AUTH_ENABLED=true
AUTH_COOKIE_NAME=xsticq_session
# 与网关同一个密钥（openssl rand -hex 32 生成，三处同值：网关/Telos/Kairos）
AUTH_JWT_SECRET=
AUTH_JWT_ALG=HS256
AUTH_GATEWAY_URL=https://id.xsticq.com
# 需要整页登录的路径前缀（默认空=免登录全功能可用）
AUTH_PROTECTED_PREFIXES=

# ── 导出（无头浏览器回访自身渲染打印页，生产走本机回环）──
EXPORT_BASE_URL=http://127.0.0.1:3000

# ── 模板分享库（SQLite 文件路径；建议放数据目录并纳入备份）──
TELOS_DB_PATH=/opt/telos-data/telos.db

# ── 错误上报（可选）──
# 留空则错误只打结构化 JSON 到日志(journalctl -u telos)；填了则同时转发到该地址
# (Sentry 的 ingest URL / Slack webhook / 任意收集器)
ERROR_WEBHOOK_URL=
